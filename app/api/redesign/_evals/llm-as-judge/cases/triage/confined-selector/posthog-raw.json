 rgb(245, 245, 247); color: rgb(29, 29, 31); }.app { max-width: 480px; margin: 0px auto; padding: 32px 20px 80px; }.app-header { margin-bottom: 20px; }.app-title { font-size: 32px; font-weight: 700; margin: 0px; letter-spacing: -0.02em; }.app-subtitle { margin: 4px 0px 0px; font-size: 14px; color: rgb(110, 110, 115); font-style: italic; }.add-item-form { display: flex; gap: 8px; background: rgb(255, 255, 255); padding: 12px; border-radius: 10px; box-shadow: rgba(0, 0, 0, 0.06) 0px 1px 3px; margin-bottom: 20px; }.add-item-input { flex: 1 1 0%; border: 1px solid rgb(210, 210, 215); border-radius: 6px; padding: 10px 12px; font-size: 15px; outline: none; }.add-item-input:focus { border-color: rgb(0, 113, 227); }.add-item-button { background: rgb(0, 113, 227); color: rgb(255, 255, 255); border-width: medium; border-style: none; border-color: currentcolor; border-image: none; border-radius: 6px; padding: 10px 18px; font-size: 15px; font-weight: 500; cursor: pointer; }.add-item-button:hover { background: rgb(0, 91, 181); }.todo-list { list-style: none; padding: 0px; margin: 0px; background: rgb(255, 255, 255); border-radius: 10px; box-shadow: rgba(0, 0, 0, 0.06) 0px 1px 3px; overflow: hidden; }.todo-item { display: flex; align-items: center; gap: 12px; padding: 18px 16px; border-bottom: 1px solid rgb(236, 236, 236); }.todo-item:last-child { border-bottom-width: medium; border-bottom-style: none; border-bottom-color: currentcolor; }.todo-checkbox { width: 18px; height: 18px; cursor: pointer; }.todo-text { font-size: 15px; }.case-index { list-style: none; padding: 0px; margin: 0px; display: flex; flex-direction: column; gap: 12px; }.case-index-link { display: flex; flex-direction: column; gap: 4px; background: rgb(255, 255, 255); padding: 16px; border-radius: 10px; box-shadow: rgba(0, 0, 0, 0.06) 0px 1px 3px; text-decoration: none; color: inherit; }.case-index-link:hover { background: rgb(250, 250, 250); }.case-index-title { font-size: 16px; font-weight: 600; color: rgb(0, 113, 227); }.case-index-description { font-size: 13px; color: rgb(110, 110, 115); }.confirm-prompt { display: flex; align-items: center; gap: 8px; margin-left: auto; }.confirm-prompt-text { font-size: 13px; color: rgb(110, 110, 115); }.confirm-prompt-yes, .confirm-prompt-cancel { border: 1px solid rgb(210, 210, 215); background: rgb(255, 255, 255); border-radius: 6px; padding: 4px 10px; font-size: 13px; cursor: pointer; }.confirm-prompt-yes { background: rgb(0, 113, 227); color: rgb(255, 255, 255); border-color: rgb(0, 113, 227); }.confirm-prompt-yes:hover { background: rgb(0, 91, 181); }.confirm-prompt-cancel:hover { background: rgb(245, 245, 247); }.tab-bar { display: flex; gap: 4px; background: rgb(255, 255, 255); padding: 4px; border-radius: 10px; box-shadow: rgba(0, 0, 0, 0.06) 0px 1px 3px; margin-bottom: 12px; }.tab-button { flex: 1 1 0%; border-width: medium; border-style: none; border-color: currentcolor; border-image: none; background: transparent; border-radius: 6px; padding: 8px 12px; font-size: 14px; font-weight: 500; color: rgb(110, 110, 115); cursor: pointer; }.tab-button-active { background: rgb(0, 113, 227); color: rgb(255, 255, 255); }.todo-empty .todo-text { color: rgb(110, 110, 115); font-style: italic; }.app-well-designed { padding-top: 0px; }.well-sticky-header { position: sticky; top: 0px; background: rgb(245, 245, 247); padding: 24px 0px 16px; z-index: 10; margin-bottom: 16px; }.app-subtitle-clean { margin: 4px 0px 16px; font-size: 14px; color: rgb(29, 29, 31); font-style: normal; }.add-item-button:disabled { background: rgb(176, 212, 245); cursor: not-allowed; }.well-list .todo-item-completed .todo-text { color: rgb(134, 134, 139); text-decoration: line-through; }","isStyle":true,"id":21}],"id":20}],"id":4},{"type":3,"textContent":"\n  ","id":22},{"type":2,"tagName":"body","attributes":{},"childNodes":[{"type":3,"textContent":"\n    ","id":24},{"type":2,"tagName":"div","attributes":{"id":"root"},"childNodes":[{"type":2,"tagName":"div","attribu